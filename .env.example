# =============================================================================
# MSM Site - Variáveis de ambiente
# Copie este arquivo para .env.local e preencha conforme necessário
# =============================================================================

# ----- Site (público) -----
NEXT_PUBLIC_SITE_URL=https://msm.com.br

# Onde a rota /login redireciona o representante (app externo).
# Se vazio, exibe fallback "portal disponibilizado em breve".
NEXT_PUBLIC_REPRESENTATIVE_APP_URL=

# ----- Supabase (v1.0) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NUNCA exposta no frontend. Apenas em server actions / API routes.
SUPABASE_SERVICE_ROLE_KEY=
# Conexão direta (porta 5432) — usada por scripts/apply-migrations.mjs (schema base em supabase/migrations/)
# Formato: postgresql://postgres:<senha>@<host>:5432/postgres
# Encontrar em: Supabase dashboard → Project Settings → Database → Connection string → URI (Direct)
DIRECT_URL=

# Conexão usada por `npm run migrate` / `npm run seed` (scripts/apply-seed.mjs → aplica scripts/*.sql).
# Normalmente o MESMO valor de DIRECT_URL. Necessária p/ aplicar seeds/ajustes (ex: 014-certifications).
DATABASE_URL=

# ----- MullerBot / Webhook CRM (v1.0) -----
# Pode ficar vazio no início; admin exibe "integração não configurada".
MULLERBOT_WEBHOOK_URL=
MULLERBOT_API_KEY=

# ----- Anti-spam: Cloudflare Turnstile (v1.1) -----
# Site key de teste em desenvolvimento: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----- Rate limiting: Upstash Redis (v1.1) -----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Cache / ISR (v1.1) -----
# Gerar uma string aleatória forte (ex: openssl rand -hex 32)
REVALIDATE_SECRET=

# ----- Cron job auth (v1.1) -----
# Protege /api/cron/process-webhook-queue contra chamadas externas.
# No Railway: criar um serviço Cron no dashboard com o comando:
#   curl -s -f -H "Authorization: Bearer $CRON_SECRET" https://<dominio>/api/cron/process-webhook-queue
# Schedule sugerido: */5 * * * *
# Gerar com: openssl rand -hex 32
CRON_SECRET=
