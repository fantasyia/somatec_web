{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/a-somatec/quem-somos",
        "http://localhost:3000/solucoes/protecao-contra-surtos",
        "http://localhost:3000/contato"
      ],
      "startServerCommand": "npm start -- -p 3000",
      "startServerReadyPattern": "Ready in|started server on",
      "startServerReadyTimeout": 60000,
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1
        }
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "//": "SEO em warn (não error) DE PROPÓSITO: o site está noindex por decisão de negócio (pré-lançamento, SITE_NOINDEX=true). Enquanto for noindex, is-crawlable derruba o SEO — não é regressão de qualidade. Reverter pra error quando liberar a indexação no Google.",
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "is-crawlable": "off",

        "uses-text-compression": "off",
        "csp-xss": "off",
        "is-on-https": "off",
        "redirects-http": "off",
        "uses-http2": "off",
        "uses-long-cache-ttl": "off",

        "color-contrast": "warn",
        "image-size-responsive": "warn",
        "render-blocking-resources": "warn",
        "unused-css-rules": "warn",
        "unused-javascript": "warn",
        "modern-image-formats": "warn",

        "//insights": "Auditorias 'insight' do Lighthouse 12 são majoritariamente do runtime do Next (polyfills, chunking, request tree), não do código do site — mantidas em warn (mesma classe de render-blocking/unused-js acima). Reavaliar ao subir de versão do Next.",
        "legacy-javascript-insight": "warn",
        "forced-reflow-insight": "warn",
        "image-delivery-insight": "warn",
        "network-dependency-tree-insight": "warn",
        "render-blocking-insight": "warn",
        "cache-insight": "warn",
        "dom-size-insight": "warn",
        "offscreen-images": "warn",
        "uses-responsive-images": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
